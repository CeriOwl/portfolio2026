---
import Aside from "../components/aside.astro"
const data = [
  {text: "years of experience", num: "+2"},
  {text: "projects completed", num: "+8"},
  {text: "cups of coffee", num: "∞"},
]
---
<main class="relative z-10 bg-surface min-h-1200 h-full">
  <div class="max-w-6xl w-full h-full mx-auto py-20 px-10 flex gap-10">
    <Aside/>
    <section class="w-full flex flex-col gap-20">
      <h1 class="uppercase font-black flex flex-col text-7xl text-text">
        full-stack
        <span class="text-muted">Developer</span>
      </h1>
      <div class="flex gap-6">
        {
        data.map(e => (
        <div class="text-xl w-full max-w-40 flex flex-col items-center gap-2 text-text font-medium">
            <span class="text-6xl">{e.num}</span>
            <p class="uppercase text-md text-center">{e.text}</p>
          </div>
        ))
        }
      </div>
    </section>
  </div>
</main>
