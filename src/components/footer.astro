---
import { Image } from "astro:assets"
import X from "../assets/X.png"
import LinkedIn from "../assets/LinkedIn.png"
import Github from "../assets/Github.png"
const socialMedia = [
  {title: "X", img: X, href: "https://x.com/codedbyalex"},
  {title: "LinkedIn", img: LinkedIn, href: "www.linkedin.com/in/alejandrocamachoo"},
  {title: "Github", img: Github, href: "https://github.com/CeriOwl"}
]
---
<footer>
  <div class="max-w-7xl mx-auto flex items-center md:items-start flex-col md:flex-row gap-y-8 justify-between px-8 py-10 text-sm md:text-md">
    <p class="max-w-sm text-center md:text-start lg:max-w-md">Right now I'm available to work as a freelance. So if you wanna hire me for a project, contact me or idk, send me an email to <a class="underline text-white/70 hover:text-white transition-colors" href="mailto:alejandro.camacho.olivares@gmail.com">alejandro.camacho.olivares@gmail.com</a></p>
    <div class="flex flex-col gap-6">
      <p>Or if you prefer, here's my social media</p>
      <div class="flex justify-between">
        {
        socialMedia.map(e => (
        <a href={e.href} target="_blank">
          <Image class="w-20" src={e.img} alt={`Link a ${e.title}`}/>
        </a>
        ))
        }
      </div>
    </div>
  </div>
</footer>
